# Twilio WhatsApp Credentials
# Get these from your Twilio Console (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Optional: custom SQLite path. If omitted, the app uses ./database.db.
# PHARMACY_DB_PATH=database.db

# Store identity used in SMS templates
PHARMACY_STORE_NAME=Selvam Medicals

# SMS provider settings
SMS_PROVIDER_MODE=auto
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=
SMS_PROVIDER_SENDER=Selvam Medicals
SMS_PROVIDER_TIMEOUT=15
