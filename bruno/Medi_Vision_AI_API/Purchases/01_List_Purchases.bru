meta {
  name: List Purchases
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/purchases
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("List purchases returns an array", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.be.an('array');
  });
}
