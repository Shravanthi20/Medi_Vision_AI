meta {
  name: List Doctors
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/doctors
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("List doctors returns an array", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.be.an('array');
  });
}
