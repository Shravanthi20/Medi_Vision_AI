meta {
  name: Customer Ledger
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/customers/{{customerId}}/ledger
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("Customer ledger returns an array", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.be.an('array');
  });
}
