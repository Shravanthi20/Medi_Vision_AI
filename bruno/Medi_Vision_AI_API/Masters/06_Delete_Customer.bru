meta {
  name: Delete Customer
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/api/customers/{{customerId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("Delete customer succeeds", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.have.property('status', 'success');
  });
}
