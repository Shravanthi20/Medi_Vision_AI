meta {
  name: Dashboard
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("Dashboard loads", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.be.a('string');
    expect(body.length).to.be.greaterThan(0);
  });
}
