meta {
  name: Delete Communication Template
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api/communications/templates/{{commTemplateId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("Delete communication template succeeds", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.have.property('status', 'success');
  });
}
