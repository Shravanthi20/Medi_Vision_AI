meta {
  name: SMS Messages By Customer
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/sms/messages/by-customer/{{customerId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("SMS messages by customer returns an array", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.be.an('array');
  });
}
