meta {
  name: Update SMS Message
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/api/sms/messages/{{messageId}}
  body: json
  auth: none
}

body:json {
  {
    "body": "Updated SMS body",
    "send_status": "queued"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("Update SMS message succeeds", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.have.property('id');
  });
}
