meta {
  name: SMS Messages By Bill
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/sms/messages/by-bill/{{billId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("SMS messages by bill returns an array", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.be.an('array');
  });
}
