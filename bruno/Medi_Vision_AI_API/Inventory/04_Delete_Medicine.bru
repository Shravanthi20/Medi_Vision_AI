meta {
  name: Delete Medicine
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api/medicines/{{medicineId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("Delete medicine succeeds", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.have.property('status', 'success');
  });
}
