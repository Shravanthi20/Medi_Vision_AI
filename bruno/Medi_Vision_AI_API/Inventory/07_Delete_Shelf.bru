meta {
  name: Delete Shelf
  type: http
  seq: 7
}

delete {
  url: {{baseUrl}}/api/shelves/{{shelfId}}
  body: none
  auth: none
}

assert {
  res.status: eq 200
}

tests {
  test("Delete shelf succeeds", function() {
    const body = res.getBody();
    expect(res.getStatus()).to.equal(200);
    expect(body).to.have.property('status', 'success');
  });
}
